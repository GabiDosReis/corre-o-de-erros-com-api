import customtkinter # importa a biblioteca customtkinter

customtkinter.set_appearance_mode("white") # método utilizado para colocar o modo de cores de fundo

app = customtkinter.CTk() # app se torna a tela principal, o aplicativo
app.geometry("800x800") # aqui chamamos o método geometria onde colocamos a resolução do app
app.title("My program") # aqui colocamos o título do app, o nome que fica na janela quando o mesmo é executado




