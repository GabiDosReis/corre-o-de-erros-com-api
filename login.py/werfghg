label = customtkinter.CTkLabel(app,text="Seja bem vindo à calculadora",fg_color="transparent") #aqui label é uma variável que se torna um objeto com label através do comando CTKLabel, os parâmetros da função são atributos que vai conter no item como: app = diz onde que esta label irá ser implementada, text = é o texto que vai aparecer, fg_color = é a cor do item, se é transparente...  nesses atributos é possível colocar bordas, estilizar mais. Para isto leia mais a documentação do mesmo

label.pack() # aqui é como posicionamos o label, após criar o mesmo na opção acima, precisamos posicionar o mesmo. o ,pack posiciona de forma automática e seguindo a ordem.


input_conta = customtkinter.CTkEntry(app,placeholder_text="Digite a conta que deseja fazer") # aqui é a mesma coisa que o label porém agora é um Entry ou seja, uma caixa de entrada de dados, um input. Que tem os atributos igual o de cima

input_conta.pack() # aqui posicionamos de forma automática, lembrando que o .pack por ser o segundo ele será colocado abaixo do label acima.


resultado_label = customtkinter.CTkLabel(app,text="") # aqui é o mesmo conceito porém só tem menos atributo, um atributo obrigatório em todos (você deve ter percebido), é o app, o nome da tela que o item irá ser colocado. 

resultado_label.pack() #aqui é o pocisionamento automático, por ele ser o 3º item ele ficará abaixo do input_conta


button = customtkinter.CTkButton(app,text="Calcular",command=button_click_event  ) #aqui é um botão mais segue a mesma lógica dos elementos acima

button.pack() #...

app.mainloop() # este é comando que deve ser executado por último, ele dita que irá abrir a tela do app e executar o mesmo.